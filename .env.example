# GEMINI_API_KEY: Required for generative AI API calls.
# Cloud environment injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Cloud environment injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
